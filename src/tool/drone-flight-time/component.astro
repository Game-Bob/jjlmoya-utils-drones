---
const { ui } = Astro.props;
import BatterySpecs from "./components/BatterySpecs.astro";
import ConsumptionStats from "./components/ConsumptionStats.astro";
import FlightDashboard from "./components/FlightDashboard.astro";
import AutonomyChart from "./components/AutonomyChart.astro";
---

<div class="flight-calculator-ui">
    <div class="tech-mega-card animate-in fade-in zoom-in duration-700">
        <div class="card-grid">
            <div class="config-sidebar">
                <BatterySpecs ui={ui} />
                <div class="divider"></div>
                <ConsumptionStats ui={ui} />
            </div>
            
            <div class="main-display">
                <FlightDashboard ui={ui} />
                <div class="divider"></div>
                <AutonomyChart ui={ui} />
            </div>
        </div>
    </div>
</div>

<script>
    import { Chart, registerables } from "chart.js";
    Chart.register(...registerables);

    const capInput = document.getElementById("capacityInput") as HTMLInputElement;
    const cellsInput = document.getElementById("cellsInput") as HTMLSelectElement;
    const safetyInput = document.getElementById("safetyInput") as HTMLInputElement;
    const drawInput = document.getElementById("drawInput") as HTMLInputElement;
    const wattsInput = document.getElementById("wattsInput") as HTMLInputElement;
    const effInput = document.getElementById("efficiencyInput") as HTMLInputElement;

    const displays = {
        cap: document.getElementById("capDisplay"),
        cells: document.getElementById("cellsDisplay"),
        volts: document.getElementById("voltsDisplay"),
        safety: document.getElementById("safetyDisplay"),
        draw: document.getElementById("drawDisplay"),
        watts: document.getElementById("wattsDisplay"),
        eff: document.getElementById("effDisplay"),
        timeMain: document.getElementById("timeMainDisplay"),
        timeTotal: document.getElementById("timeTotalDisplay"),
        wh: document.getElementById("whDisplay"),
        co2: document.getElementById("co2Display"),
        circle: document.getElementById("timeCircle")
    };

    let chart: Chart | null = null;

    function getChartConfig(label: string) {
        return {
            type: "line",
            data: {
                labels: [],
                datasets: [{
                    label,
                    data: [],
                    borderColor: "#f97316",
                    backgroundColor: "rgba(249, 115, 22, 0.1)",
                    borderWidth: 3,
                    fill: true,
                    tension: 0.4,
                    pointRadius: 0,
                    pointHitRadius: 10
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: { legend: { display: false } },
                scales: {
                    y: { beginAtZero: true, grid: { color: "rgba(0,0,0,0.05)" } },
                    x: { grid: { display: false } }
                }
            }
        };
    }

    function initChart() {
        const canvas = document.getElementById("autonomyChart") as HTMLCanvasElement;
        const ctx = canvas?.getContext("2d");
        if (!ctx) return;
        const chartLabel = canvas.dataset.label || "Minutos";
        chart = new Chart(ctx, getChartConfig(chartLabel));
    }

    function calculate(source: string) {
        const cap = parseFloat(capInput.value);
        const cells = parseInt(cellsInput.value);
        const safety = parseFloat(safetyInput.value) / 100;
        let draw = parseFloat(drawInput.value);
        const voltage = cells * 3.7;

        if (source === 'watts') {
            draw = parseFloat(wattsInput.value) / voltage;
            drawInput.value = draw.toFixed(1);
        } else {
            wattsInput.value = (draw * voltage).toFixed(1);
        }

        const state = { cap, cells, safety, draw, voltage };
        updateDisplays(state);

        const usableAh = (cap / 1000) * safety;
        const totalAh = cap / 1000;

        const safeTimeMin = (usableAh / draw) * 60;
        const totalTimeMin = (totalAh / draw) * 60;

        const energyWh = (cap / 1000) * voltage;

        renderResults(safeTimeMin, totalTimeMin, energyWh, cap);
        updateChart(usableAh);
    }

    function updateDisplays(state: { cap: number; cells: number; safety: number; draw: number; voltage: number }) {
        if (displays.cap) displays.cap.textContent = state.cap.toString();
        if (displays.cells) displays.cells.textContent = state.cells.toString();
        if (displays.volts) displays.volts.textContent = state.voltage.toFixed(1);
        if (displays.safety) displays.safety.textContent = Math.round(state.safety * 100).toString();
        if (displays.draw) displays.draw.textContent = state.draw.toFixed(1);
        if (displays.watts) displays.watts.textContent = (state.draw * state.voltage).toFixed(1);
        if (displays.eff) displays.eff.textContent = effInput.value;
    }

    function renderResults(safeMin: number, totalMin: number, wh: number, cap: number) {
        if (displays.timeMain) displays.timeMain.textContent = formatTime(safeMin);
        if (displays.timeTotal) displays.timeTotal.textContent = formatTime(totalMin);
        if (displays.wh) displays.wh.textContent = `${wh.toFixed(1)} Wh`;
        if (displays.co2) displays.co2.textContent = `${Math.round(cap * 0.05)} g`;

        if (displays.circle) {
            const limit = 20;
            const progress = Math.min(safeMin / limit, 1);
            const offset = 283 - (progress * 283);
            displays.circle.style.strokeDashoffset = offset.toString();
        }
    }

    function formatTime(decimalMin: number) {
        if (isNaN(decimalMin) || decimalMin === Infinity) return "0:00";
        const mins = Math.floor(decimalMin);
        const secs = Math.floor((decimalMin - mins) * 60);
        return `${mins}:${secs.toString().padStart(2, '0')}`;
    }

    function updateChart(usableAh: number) {
        if (!chart) return;
        const data: number[] = [];
        const labels: string[] = [];
        const currentDraw = parseFloat(drawInput.value);

        for (let a = Math.max(1, currentDraw - 20); a <= currentDraw + 20; a += 2) {
            labels.push(`${a}A`);
            const val = ((usableAh / a) * 60);
            data.push(Number(val.toFixed(1)));
        }

        chart.data.labels = labels;
        if (chart.data.datasets[0]) chart.data.datasets[0].data = data;
        chart.update('none');
    }

    [capInput, cellsInput, safetyInput, drawInput, effInput].forEach(el => {
        el?.addEventListener("input", () => calculate('basic'));
    });

    wattsInput?.addEventListener("input", () => calculate('watts'));

    document.querySelectorAll('.preset-btn').forEach(btn => {
        btn.addEventListener('click', () => {
            capInput.value = btn.getAttribute('data-val') || "1500";
            calculate('basic');
        });
    });

    initChart();
    calculate('basic');
</script>

<style>
.flight-calculator-ui {
  --dft-accent: #f97316;
  --dft-accent-glow: rgba(249, 115, 22, 0.15);
  --dft-bg: #fff;
  --dft-bg-muted: #f5f5f5;
  --dft-bg-surface: #eee;
  --dft-bg-overlay: #f0f0f0;
  --dft-text: #1a1a1a;
  --dft-text-muted: #4a4a4a;
  --dft-text-dim: #707070;
  --dft-border: #d0d0d0;
  --dft-border-light: #e8e8e8;
  --dft-shadow: 0 30px 60px rgba(0, 0, 0, 0.08);
  --dft-success: #15803d;
  --dft-success-bg: #dcfce7;
  --dft-warning: #a16207;
  --dft-warning-bg: #fef9c3;
  --dft-danger: #b91c1c;
  --dft-danger-bg: #fee2e2;

  width: 100%;
  max-width: 1100px;
  margin: 0 auto;
}

:global([data-theme="dark"]) .flight-calculator-ui,
:global(.theme-dark) .flight-calculator-ui {
  --dft-bg: #1a1a1a;
  --dft-bg-muted: #2d2d2d;
  --dft-bg-surface: #3a3a3a;
  --dft-bg-overlay: #292929;
  --dft-text: #f5f5f5;
  --dft-text-muted: #b0b0b0;
  --dft-text-dim: #888;
  --dft-border: #4a4a4a;
  --dft-border-light: #525252;
  --dft-shadow: 0 30px 60px rgba(0, 0, 0, 0.08);
  --dft-success: #4ade80;
  --dft-success-bg: rgba(21, 128, 61, 0.15);
  --dft-warning: #facc15;
  --dft-warning-bg: rgba(161, 98, 7, 0.15);
  --dft-danger: #f87171;
  --dft-danger-bg: rgba(185, 28, 28, 0.15);
}

.flight-calculator-ui .tech-mega-card {
  background: var(--dft-bg);
  backdrop-filter: blur(20px);
  border: 1px solid var(--dft-border);
  border-radius: 32px;
  box-shadow: var(--dft-shadow);
  overflow: hidden;
}

.flight-calculator-ui .card-grid {
  display: grid;
  grid-template-columns: 380px 1fr;
}

.flight-calculator-ui .config-sidebar {
  padding: 2.5rem;
  background: var(--dft-bg-overlay);
  display: flex;
  flex-direction: column;
  gap: 2.5rem;
  border-right: 1px solid var(--dft-border-light);
}

:global([data-theme="dark"]) .flight-calculator-ui .config-sidebar,
:global(.theme-dark) .flight-calculator-ui .config-sidebar {
  background: var(--dft-bg-surface);
  border-right-color: var(--dft-border-light);
}

.flight-calculator-ui .main-display {
  padding: 2.5rem;
  display: flex;
  flex-direction: column;
  gap: 2.5rem;
  background: var(--dft-bg);
}

:global([data-theme="dark"]) .flight-calculator-ui .main-display,
:global(.theme-dark) .flight-calculator-ui .main-display {
  background: var(--dft-bg);
}

.flight-calculator-ui .divider {
  height: 1px;
  width: 100%;
  background: linear-gradient(90deg, transparent, var(--dft-border-light), transparent);
}

:global([data-theme="dark"]) .flight-calculator-ui .divider,
:global(.theme-dark) .flight-calculator-ui .divider {
  background: linear-gradient(90deg, transparent, var(--dft-border-light), transparent);
}

.flight-calculator-ui .tech-section {
  display: flex;
  flex-direction: column;
  gap: 1.5rem;
}

.flight-calculator-ui .section-title {
  font-size: 0.95rem;
  font-weight: 800;
  color: var(--dft-text);
  text-transform: uppercase;
  letter-spacing: 0.05em;
  margin: 0;
}

.flight-calculator-ui .input-group {
  display: flex;
  flex-direction: column;
  gap: 0.75rem;
}

.flight-calculator-ui .label-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.flight-calculator-ui .input-group label {
  font-size: 0.85rem;
  font-weight: 700;
  color: var(--dft-text-muted);
}

.flight-calculator-ui .value-badge {
  padding: 0.25rem 0.75rem;
  background: var(--dft-accent-glow);
  border-radius: 12px;
  color: var(--dft-accent);
  font-weight: 800;
  font-size: 0.9rem;
}

.flight-calculator-ui .tech-slider {
  width: 100%;
  height: 6px;
  appearance: none;
  background: var(--dft-border);
  border-radius: 3px;
  outline: none;
}

.flight-calculator-ui .tech-slider::-webkit-slider-thumb {
  appearance: none;
  width: 18px;
  height: 18px;
  background: var(--dft-accent);
  border: 3px solid var(--dft-bg);
  border-radius: 50%;
  cursor: pointer;
}

.flight-calculator-ui .tech-slider::-moz-range-thumb {
  width: 18px;
  height: 18px;
  background: var(--dft-accent);
  border: 3px solid var(--dft-bg);
  border-radius: 50%;
  cursor: pointer;
}

.flight-calculator-ui .tech-select {
  width: 100%;
  padding: 0.75rem;
  background: var(--dft-bg-surface);
  border: 1px solid var(--dft-border);
  border-radius: 12px;
  font-weight: 600;
  color: var(--dft-text);
}

.flight-calculator-ui .tech-input {
  width: 100%;
  padding: 0.75rem;
  background: var(--dft-bg-surface);
  border: 1px solid var(--dft-border);
  border-radius: 12px;
  font-weight: 600;
  color: var(--dft-text);
}

.flight-calculator-ui .presets {
  display: flex;
  gap: 0.5rem;
  flex-wrap: wrap;
}

.flight-calculator-ui .preset-btn {
  padding: 0.35rem 0.65rem;
  background: var(--dft-bg-surface);
  border: none;
  border-radius: 8px;
  font-size: 0.75rem;
  font-weight: 700;
  color: var(--dft-text-muted);
  cursor: pointer;
  transition: all 0.2s;
}

.flight-calculator-ui .preset-btn:hover {
  background: var(--dft-border);
  color: var(--dft-text);
}

.flight-calculator-ui .hint {
  font-size: 0.75rem;
  color: var(--dft-text-dim);
}

.flight-calculator-ui .dashboard-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 2rem;
}

.flight-calculator-ui .main-result {
  display: flex;
  justify-content: center;
}

.flight-calculator-ui .radial-container {
  position: relative;
  width: 240px;
  height: 240px;
  display: flex;
  justify-content: center;
  align-items: center;
}

.flight-calculator-ui .radial-svg {
  transform: rotate(-90deg);
  width: 100%;
  height: 100%;
}

.flight-calculator-ui .bg-circle {
  fill: none;
  stroke: var(--dft-bg-surface);
  stroke-width: 8;
}

.flight-calculator-ui .fg-circle {
  fill: none;
  stroke: var(--dft-accent);
  stroke-width: 8;
  stroke-linecap: round;
  stroke-dasharray: 283;
  stroke-dashoffset: 0;
  transition: stroke-dashoffset 0.8s cubic-bezier(0.4, 0, 0.2, 1);
}

.flight-calculator-ui .result-text {
  position: absolute;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.25rem;
}

.flight-calculator-ui .time-primary {
  font-size: 4.5rem;
  font-weight: 950;
  color: var(--dft-text);
  letter-spacing: -0.05em;
  line-height: 1;
}

.flight-calculator-ui .time-label {
  font-size: 0.9rem;
  font-weight: 800;
  color: var(--dft-text-muted);
  text-transform: uppercase;
  letter-spacing: 0.1em;
}

.flight-calculator-ui .secondary-stats {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1.5rem;
  width: 100%;
}

.flight-calculator-ui .stat-box {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.25rem;
  padding: 1.25rem;
  background: var(--dft-bg-overlay);
  border: 1px solid var(--dft-border-light);
  border-radius: 20px;
}

:global([data-theme="dark"]) .flight-calculator-ui .stat-box,
:global(.theme-dark) .flight-calculator-ui .stat-box {
  background: var(--dft-bg-muted);
  border-color: var(--dft-border);
}

.flight-calculator-ui .stat-label {
  font-size: 0.7rem;
  font-weight: 700;
  color: var(--dft-text-dim);
  text-transform: uppercase;
  text-align: center;
}

.flight-calculator-ui .stat-value {
  font-size: 1.2rem;
  font-weight: 900;
  color: var(--dft-text);
}

.flight-calculator-ui .chart-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 1rem;
}

.flight-calculator-ui .chart-subtitle {
  font-size: 0.85rem;
  font-weight: 600;
  color: var(--dft-text-muted);
}

.flight-calculator-ui .chart-body {
  position: relative;
  height: 300px;
  width: 100%;
}

@media (max-width: 992px) {
  .flight-calculator-ui .card-grid {
    grid-template-columns: 1fr;
  }

  .flight-calculator-ui .config-sidebar {
    border-right: none;
    border-bottom: 1px solid var(--dft-border-light);
  }

  :global([data-theme="dark"]) .flight-calculator-ui .config-sidebar,
  :global(.theme-dark) .flight-calculator-ui .config-sidebar {
    border-bottom-color: var(--dft-border-light);
  }
}

@media (max-width: 600px) {
  .flight-calculator-ui .secondary-stats {
    grid-template-columns: 1fr;
  }

  .flight-calculator-ui .radial-container {
    width: 200px;
    height: 200px;
  }

  .flight-calculator-ui .time-primary {
    font-size: 3.5rem;
  }
}
</style>
