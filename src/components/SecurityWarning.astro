---
import { Icon } from "astro-icon/components";

interface Props {
	title: string;
	message: string;
}

const { title, message } = Astro.props;
---

<div class="security-warning">
	<div class="warning-icon-wrapper">
		<Icon name="mdi:alert-decagram" class="warning-icon" />
	</div>
	<div class="warning-content">
		<p>
			<strong class="warning-title">{title}:</strong>
			<span class="warning-message">{message}</span>
		</p>
	</div>
	<div class="warning-accent"></div>
</div>

<style>
	.security-warning {
		position: relative;
		display: flex;
		align-items: center;
		gap: 1.5rem;
		padding: 1.5rem 2rem;
		background: rgba(239, 68, 68, 0.05);
		backdrop-filter: blur(10px);
		border: 1px solid rgba(239, 68, 68, 0.2);
		border-radius: 24px;
		overflow: hidden;
		transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
		margin: 2rem 0;
	}

	:global(.theme-dark) .security-warning {
		background: rgba(239, 68, 68, 0.1);
		border-color: rgba(239, 68, 68, 0.3);
	}

	.security-warning:hover {
		transform: translateY(-4px) scale(1.01);
		box-shadow: 0 20px 40px rgba(239, 68, 68, 0.15);
		border-color: rgba(239, 68, 68, 0.4);
	}

	.warning-icon-wrapper {
		flex-shrink: 0;
		display: flex;
		align-items: center;
		justify-content: center;
		width: 48px;
		height: 48px;
		background: linear-gradient(135deg, #ef4444, #b91c1c);
		border-radius: 16px;
		box-shadow: 0 8px 16px rgba(239, 68, 68, 0.3);
		animation: pulse-ring 3s cubic-bezier(0.25, 0.8, 0.25, 1) infinite;
	}

	.warning-icon {
		--icon-color: #fff;

		width: 28px;
		height: 28px;
		color: var(--icon-color);
	}

	.warning-content {
		flex: 1;
	}

	.warning-content p {
		margin: 0;
		color: var(--antenna-text);
		font-size: 0.95rem;
		line-height: 1.6;
	}

	.warning-title {
		--warning-color: #ef4444;

		color: var(--warning-color);
		font-weight: 800;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		font-size: 0.85rem;
	}

	.warning-message {
		font-weight: 500;
		opacity: 0.9;
	}

	.warning-accent {
		position: absolute;
		top: 0;
		left: 0;
		height: 100%;
		width: 4px;
		background: #ef4444;
	}

	@keyframes pulse-ring {
		0% {
			box-shadow: 0 0 0 0 rgba(239, 68, 68, 0.4);
		}

		70% {
			box-shadow: 0 0 0 10px rgba(239, 68, 68, 0);
		}

		100% {
			box-shadow: 0 0 0 0 rgba(239, 68, 68, 0);
		}
	}

	@media (max-width: 600px) {
		.security-warning {
			flex-direction: column;
			align-items: flex-start;
			gap: 1rem;
			padding: 1.5rem;
		}

		.warning-icon-wrapper {
			width: 40px;
			height: 40px;
		}

		.warning-icon {
			width: 24px;
			height: 24px;
		}
	}
</style>
